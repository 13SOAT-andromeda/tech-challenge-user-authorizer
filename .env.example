JWT_SECRET=xxx
JWT_ISSUER=tech-challenge-s1
SESSION_TABLE_NAME=user-sessions

# DynamoDB client (internal/session/store.go, NewDynamoStore)
AWS_REGION=us-east-1
# LocalStack a partir da Lambda em container: ex. http://host.docker.internal:4566 ou http://172.17.0.1:4566
# Deixe vazio ou comente para usar o endpoint padrão da AWS (Dynamo real).
# DYNAMODB_ENDPOINT=http://host.docker.internal:4566

# LocalStack (docker-compose): verbosidade no stdout — útil com `make container-logs`
# LS_LOG=warning
